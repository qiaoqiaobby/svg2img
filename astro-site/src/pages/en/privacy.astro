---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Footer from '@/components/Footer.astro';
import { t } from '@/i18n';

const lang = 'en' as const;
const translations = t(lang);
---

<BaseLayout lang={lang} title={`${translations.privacyTitle} | SVG2Img`} description={translations.privacyContent}>
  <div class="container">
    <header style="margin-bottom: 2rem;">
      <h1 style="font-size: 1.75rem;">{translations.privacyTitle}</h1>
      <p style="color: var(--color-text-secondary); margin-top: 0.5rem;">
        <a href={`/${lang}/`} style="color: var(--color-primary); text-decoration: none;">&larr; {translations.title}</a>
      </p>
    </header>
    <main class="privacy-content">
      <p>{translations.privacyContent}</p>

      <h2>Data Processing</h2>
      <ul>
        <li>SVG files are processed locally in your browser and are never sent to any server</li>
        <li>Converted images are stored in browser memory and automatically cleared when you close the page</li>
        <li>User preferences (theme, language) are saved locally via localStorage</li>
      </ul>

      <h2>Third-Party Services</h2>
      <p>This website is hosted on Cloudflare Pages. Cloudflare may collect basic access logs (IP address, User-Agent, etc.) for security purposes. Beyond this, no third-party analytics, advertising, or tracking services are integrated.</p>

      <h2>Open Source</h2>
      <p>The complete source code is published on <a href="https://github.com/qiaoqiaobby/svg2img" target="_blank" rel="noopener noreferrer">GitHub</a>. You can audit the code yourself to verify these privacy claims.</p>
    </main>
    <Footer lang={lang} />
  </div>
</BaseLayout>

<style>
  .privacy-content {
    max-width: 640px;
    line-height: 1.8;
    color: var(--color-text-secondary);
  }

  .privacy-content h2 {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-text);
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  .privacy-content ul {
    padding-left: 1.5rem;
  }

  .privacy-content li {
    margin-bottom: 0.5rem;
  }

  .privacy-content a {
    color: var(--color-primary);
    text-decoration: none;
  }

  .privacy-content a:hover {
    text-decoration: underline;
  }
</style>
