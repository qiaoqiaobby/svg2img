---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/components/Hero.astro';
import Features from '@/components/Features.astro';
import HowTo from '@/components/HowTo.astro';
import FormatComparison from '@/components/FormatComparison.astro';
import Faq from '@/components/Faq.astro';
import Footer from '@/components/Footer.astro';
import Converter from '@/components/converter/Converter.vue';
import { t } from '@/i18n';

const lang = 'en' as const;
const translations = t(lang);
---

<BaseLayout lang={lang} title={translations.seoTitle} description={translations.metaDescription}>
  <div class="container">
    <Hero lang={lang} />
    <Features lang={lang} />
    <main>
      <Converter lang={lang} client:visible />
    </main>
    <HowTo lang={lang} />
    <FormatComparison lang={lang} />
    <Faq lang={lang} />
    <Footer lang={lang} />
  </div>
</BaseLayout>
