---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Footer from '@/components/Footer.astro';
import { t } from '@/i18n';

const lang = 'zh' as const;
const translations = t(lang);
---

<BaseLayout lang={lang} title={`${translations.privacyTitle} | SVG2Img`} description={translations.privacyContent}>
  <div class="container">
    <header style="margin-bottom: 2rem;">
      <h1 style="font-size: 1.75rem;">{translations.privacyTitle}</h1>
      <p style="color: var(--color-text-secondary); margin-top: 0.5rem;">
        <a href={`/${lang}/`} style="color: var(--color-primary); text-decoration: none;">&larr; {translations.title}</a>
      </p>
    </header>
    <main class="privacy-content">
      <p>{translations.privacyContent}</p>

      <h2>数据处理</h2>
      <ul>
        <li>SVG 文件仅在浏览器本地处理，不会发送到任何服务器</li>
        <li>转换后的图片存储在浏览器内存中，关闭页面后自动清除</li>
        <li>用户偏好设置（主题、语言）通过 localStorage 保存在本地</li>
      </ul>

      <h2>第三方服务</h2>
      <p>本网站托管在 Cloudflare Pages 上。Cloudflare 可能会收集基本的访问日志（IP 地址、User-Agent 等）用于安全防护。除此之外，本网站不集成任何第三方分析、广告或追踪服务。</p>

      <h2>开源</h2>
      <p>本工具的完整源代码发布在 <a href="https://github.com/qiaoqiaobby/svg2img" target="_blank" rel="noopener noreferrer">GitHub</a>，您可以自行审计代码以验证上述隐私声明。</p>
    </main>
    <Footer lang={lang} />
  </div>
</BaseLayout>

<style>
  .privacy-content {
    max-width: 640px;
    line-height: 1.8;
    color: var(--color-text-secondary);
  }

  .privacy-content h2 {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-text);
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  .privacy-content ul {
    padding-left: 1.5rem;
  }

  .privacy-content li {
    margin-bottom: 0.5rem;
  }

  .privacy-content a {
    color: var(--color-primary);
    text-decoration: none;
  }

  .privacy-content a:hover {
    text-decoration: underline;
  }
</style>
