---
import '../styles/globals.css';
import '../styles/animations.css';

interface Props {
  lang: 'zh' | 'en';
  title: string;
  description: string;
}

const { lang, title, description } = Astro.props;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const zhUrl = new URL('/zh/', Astro.site);
const enUrl = new URL('/en/', Astro.site);
---

<!DOCTYPE html>
<html lang={lang === 'zh' ? 'zh-CN' : 'en'}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="theme-color" content="#f97316" />
  <link rel="icon" href="/favicon.ico" sizes="any" />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link rel="canonical" href={canonicalUrl} />
  <link rel="alternate" hreflang="zh" href={zhUrl} />
  <link rel="alternate" hreflang="en" href={enUrl} />
  <link rel="alternate" hreflang="x-default" href={enUrl} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalUrl.toString()} />
  <meta property="og:site_name" content="SVG2Img" />
  <meta property="og:locale" content={lang === 'zh' ? 'zh_CN' : 'en_US'} />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />

  <!-- Theme: prevent FOUC -->
  <script is:inline>
    (function() {
      var theme = localStorage.getItem('svg2img_theme');
      if (theme === 'dark' || theme === 'light') {
        document.documentElement.setAttribute('data-theme', theme);
      }
    })();
  </script>

  <!-- JSON-LD: WebApplication -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": title,
    "description": description,
    "url": canonicalUrl.toString(),
    "applicationCategory": "DesignApplication",
    "operatingSystem": "Any",
    "browserRequirements": "Requires a modern browser with Canvas API support",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
    "inLanguage": [lang],
  })} />
</head>
<body>
  <div class="mouse-glow" id="mouse-glow"></div>
  <slot />

  <script>
    // Theme toggle
    const toggle = document.getElementById('theme-toggle');
    if (toggle) {
      toggle.addEventListener('click', () => {
        const html = document.documentElement;
        const current = html.getAttribute('data-theme');
        const systemDark = window.matchMedia('(prefers-color-scheme: dark)').matches;

        let next: string;
        if (current === 'dark') {
          next = 'light';
        } else if (current === 'light') {
          next = 'dark';
        } else {
          // No manual override yet — toggle opposite of system
          next = systemDark ? 'light' : 'dark';
        }

        html.setAttribute('data-theme', next);
        localStorage.setItem('svg2img_theme', next);
      });
    }

    // Mouse glow
    const glow = document.getElementById('mouse-glow');
    if (glow) {
      let raf: number | null = null;
      document.addEventListener('mousemove', (e: MouseEvent) => {
        if (raf) return;
        raf = requestAnimationFrame(() => {
          glow.style.setProperty('--glow-x', e.clientX + 'px');
          glow.style.setProperty('--glow-y', e.clientY + 'px');
          glow.style.opacity = '1';
          raf = null;
        });
      });
      document.addEventListener('mouseleave', () => {
        glow.style.opacity = '0';
      });
    }
  </script>
</body>
</html>
