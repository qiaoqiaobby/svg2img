---
import { t } from '../i18n';

interface Props {
  lang: 'zh' | 'en';
}

const { lang } = Astro.props;
const translations = t(lang);
---

<section class="faq-section animate-entry" style="--entry-order: 4;">
  <h2>{translations.faqTitle}</h2>
  {translations.faq.map((item) => (
    <details>
      <summary>{item.q}</summary>
      <p>{item.a}</p>
    </details>
  ))}
</section>

<!-- JSON-LD: FAQPage -->
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": translations.faq.map(item => ({
    "@type": "Question",
    "name": item.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.a,
    },
  })),
})} />
