---
import { t } from '../i18n';

interface Props {
  lang: 'zh' | 'en';
}

const { lang } = Astro.props;
const translations = t(lang);
---

<footer class="site-footer">
  <div class="footer-links">
    <a href={`/${lang}/privacy/`}>{translations.footerPrivacy}</a>
    <a href="https://github.com/qiaoqiaobby/svg2img" target="_blank" rel="noopener noreferrer">{translations.footerOpenSource}</a>
  </div>
  <p>&copy; {new Date().getFullYear()} SVG2Img</p>
</footer>

<style>
  .footer-links {
    display: flex;
    gap: 1.5rem;
    justify-content: center;
    margin-bottom: 0.5rem;
  }

  .footer-links a {
    color: var(--color-text-secondary);
    text-decoration: none;
    font-size: 0.8125rem;
    transition: color 0.2s;
  }

  .footer-links a:hover {
    color: var(--color-primary);
  }
</style>
